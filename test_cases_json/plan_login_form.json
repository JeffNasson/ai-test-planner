[
    {
        "title": "Valid Login",
        "url": "https://the-internet.herokuapp.com/login",
        "type": "positive",
        "inputs": {
            "username": "validUser",
            "password": "validPassword"
        },
        "steps": [
            "Open the login page.",
            "Enter valid username and password.",
            "Click the login button."
        ],
        "expected": "User should be redirected to the secure area.",
        "assertion": {
            "type": "url_contains",
            "value": "/secure",
            "locator": ""
        }
    },
    {
        "title": "Invalid Login",
        "url": "https://the-internet.herokuapp.com/login",
        "type": "negative",
        "inputs": {
            "username": "invalidUser",
            "password": "wrongPassword"
        },
        "steps": [
            "Open the login page.",
            "Enter invalid username and password.",
            "Click the login button."
        ],
        "expected": "User should see an invalid username message.",
        "assertion": {
            "type": "text_present",
            "value": "Your username is invalid!",
            "locator": "#flash"
        }
    },
    {
        "title": "Empty Fields Login",
        "url": "https://the-internet.herokuapp.com/login",
        "type": "edge",
        "inputs": {
            "username": "",
            "password": ""
        },
        "steps": [
            "Open the login page.",
            "Leave username and password fields empty.",
            "Click the login button."
        ],
        "expected": "User should see required field validation.",
        "assertion": {
            "type": "text_present",
            "value": "Your username is invalid!",
            "locator": "#flash"
        }
    }
]
{
    "test_cases": [
        {
            "title": "Successful Login",
            "url": "https://the-internet.herokuapp.com/login",
            "type": "positive",
            "inputs": {
                "username": "validUser",
                "password": "validPassword"
            },
            "steps": [
                "Navigate to the login page.",
                "Enter valid username and password.",
                "Click the login button."
            ],
            "expected": "User should be redirected to the secure area.",
            "assertion": {
                "type": "url_contains",
                "value": "/secure",
                "locator": ""
            }
        },
        {
            "title": "Invalid Login Attempt",
            "url": "https://the-internet.herokuapp.com/login",
            "type": "negative",
            "inputs": {
                "username": "invalidUser",
                "password": "invalidPassword"
            },
            "steps": [
                "Navigate to the login page.",
                "Enter invalid username and password.",
                "Click the login button."
            ],
            "expected": "User should see invalid login message.",
            "assertion": {
                "type": "text_present",
                "value": "Your username is invalid!",
                "locator": "#flash"
            }
        },
        {
            "title": "Empty Fields Submission",
            "url": "https://the-internet.herokuapp.com/login",
            "type": "edge",
            "inputs": {
                "username": "",
                "password": ""
            },
            "steps": [
                "Navigate to the login page.",
                "Leave username and password fields empty.",
                "Click the login button."
            ],
            "expected": "User should see required field validation.",
            "assertion": {
                "type": "text_present",
                "value": "Your username is invalid!",
                "locator": "#flash"
            }
        }
    ]
}
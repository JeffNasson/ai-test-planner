{
    "test_cases": [
        {
            "title": "Successful login",
            "url": "https://the-internet.herokuapp.com/login",
            "type": "positive",
            "inputs": {
                "username": "validUser",
                "password": "validPass"
            },
            "steps": [
                "Open the login page",
                "Enter valid username and password",
                "Click the login button"
            ],
            "expected": "User should be redirected to the secure page",
            "assertion": {
                "type": "url_contains",
                "value": "/secure",
                "locator": ""
            }
        },
        {
            "title": "Unsuccessful login with invalid credentials",
            "url": "https://the-internet.herokuapp.com/login",
            "type": "negative",
            "inputs": {
                "username": "invalidUser",
                "password": "invalidPass"
            },
            "steps": [
                "Open the login page",
                "Enter invalid username and password",
                "Click the login button"
            ],
            "expected": "User should see an error message",
            "assertion": {
                "type": "text_present",
                "value": "Your username is invalid!",
                "locator": "#flash"
            }
        },
        {
            "title": "Login attempt with empty fields",
            "url": "https://the-internet.herokuapp.com/login",
            "type": "edge",
            "inputs": {
                "username": "",
                "password": ""
            },
            "steps": [
                "Open the login page",
                "Leave username and password fields empty",
                "Click the login button"
            ],
            "expected": "User should see required field validation",
            "assertion": {
                "type": "text_present",
                "value": "Your username is invalid!",
                "locator": "#flash"
            }
        }
    ]
}